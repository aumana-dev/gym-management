generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Member {
  id            Int       @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String    @unique
  phone         String?
  membershipType String   @default("basic")
  status        String    @default("active")
  joinDate      DateTime  @default(now())
  expiryDate    DateTime?
  photo         String?
  emergencyContact String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  workouts      Workout[]
  attendance    Attendance[]

  @@index([status])
  @@index([membershipType])
  @@index([email])
}

model Workout {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  type        String   @default("strength")
  duration    Int      @default(60)
  capacity    Int      @default(20)
  instructor  String?
  dayOfWeek   String
  startTime   String
  endTime     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     Member[]
  
  @@index([type])
  @@index([dayOfWeek])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  memberId  Int
  checkIn   DateTime @default(now())
  checkOut  DateTime?
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([checkIn])
}

model Equipment {
  id            Int      @id @default(autoincrement())
  name          String
  category      String
  status        String   @default("available")
  purchaseDate  DateTime?
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([status])
}

model GymStats {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique @default(now())
  currentOccupancy Int     @default(0)
  maxCapacity     Int      @default(100)
  dailyCheckIns   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
